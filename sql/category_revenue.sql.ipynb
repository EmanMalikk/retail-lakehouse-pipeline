   "source": [
    "-- Revenue By Product Category\n",
    "\n",
    "SELECT \n",
    "    category,\n",
    "    SUM(quantity * price) AS category_revenue\n",
    "FROM silver.silver_order_items oi\n",
    "JOIN silver.silver_products p\n",
    "ON oi.product_id = p.product_id\n",
    "GROUP BY category\n",
    "ORDER BY category_revenue DESC;"
   ]
  }
 ],
